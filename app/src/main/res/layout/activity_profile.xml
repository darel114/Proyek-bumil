<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_content_background">

    <LinearLayout
        android:id="@+id/profileHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/profile_header_green"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="64dp"> <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sisa"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="22"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minggu Kehamilan"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/profileHeader"
        android:layout_marginTop="-40dp"
        android:layout_above="@id/bottomNavigation"
        android:background="@drawable/bg_profile_content_rounded">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Biodata"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <include layout="@layout/item_profile_field"
                app:label="Nama Ibu"
                app:value="Nisa Octavia" />
            <include layout="@layout/item_profile_field"
                app:label="HPHT"
                app:value="01 Oktober 2023" />
            <include layout="@layout/item_profile_field"
                app:label="Tanggal Perkiraan Lahir (HPL)"
                app:value="07 Juli 2024" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Informasi Kesehatan"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />

            <include layout="@layout/item_profile_field"
                app:label="Riwayat Penyakit"
                app:value="Hipertensi" />
            <include layout="@layout/item_profile_field"
                app:label="Alergi"
                app:value="Tidak ada alergi" />

            <Button
                android:id="@+id/btnUbahData"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/profile_button_light_green"
                android:text="Ubah Data"
                android:textAllCaps="false"
                android:textColor="@color/profile_button_text_green"
                app:cornerRadius="25dp" />

            <Button
                android:id="@+id/btnKeluarAkun"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:text="Keluar Akun"
                android:textAllCaps="false"
                android:textColor="@color/profile_button_red"
                app:cornerRadius="25dp"
                app:strokeColor="@color/profile_button_red" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:itemIconTint="@color/profile_header_green"
        app:itemTextColor="@color/profile_header_green"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>