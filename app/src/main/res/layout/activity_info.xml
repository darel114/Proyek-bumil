<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/infoHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#66D17E"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informasi &amp; Edukasi"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Panduan kehamilan sehat untuk Ibu dan Janin"
            android:textColor="#E0F7FA"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/infoHeader"
        android:layout_above="@id/bottomNavigation"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card 1: Gizi & Nutrisi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥗 Nutrisi &amp; Gizi Ibu Hamil"
                        android:textColor="#2E7D32"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ibu hamil membutuhkan tambahan asupan kalori, asam folat, zat besi, dan kalsium. Pastikan mengonsumsi makanan bergizi seimbang seperti sayuran hijau, buah-buahan, ikan, dan susu khusus ibu hamil."
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Aktivitas Fisik -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏃‍♀️ Olahraga &amp; Aktivitas"
                        android:textColor="#0288D1"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Lakukan olahraga ringan seperti jalan santai, yoga hamil, atau senam hamil selama 30 menit sehari untuk memperlancar sirkulasi darah serta mempermudah proses persalinan."
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Tanda Bahaya -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Tanda Bahaya Kehamilan"
                        android:textColor="#D32F2F"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Segera hubungi dokter atau bidan jika mengalami gejala seperti perdarahan, demam tinggi, bengkak pada wajah dan tangan, pusing hebat, ketuban pecah dini, atau gerakan janin berkurang."
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Persiapan Persalinan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎒 Persiapan Persalinan"
                        android:textColor="#F57C00"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Siapkan tas bersalin berisi pakaian bayi, gurita, popok, pakaian ibu kancing depan, dokumen identitas (KTP, kartu BPJS), dan tentukan lokasi rumah sakit atau klinik bersalin sedari awal trimester ketiga."
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:itemIconTint="#66D17E"
        app:itemTextColor="#66D17E"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>