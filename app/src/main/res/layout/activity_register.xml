<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".RegisterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrasi Ibu Hamil"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alamat Email"
            android:inputType="textEmailAddress"
            android:minHeight="48dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Kata Sandi"
            android:inputType="textPassword"
            android:minHeight="48dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etNIK"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nomor Induk Kependudukan (NIK)"
            android:inputType="number"
            android:maxLength="16"
            android:minHeight="48dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etUmur"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Umur (Thn)"
                android:inputType="number"
                android:minHeight="48dp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etTinggi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Tinggi (cm)"
                android:inputType="numberDecimal"
                android:minHeight="48dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etBeratBadan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Berat Badan Awal (kg)"
            android:inputType="numberDecimal"
            android:minHeight="48dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Informasi Kehamilan"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPilihHPHT"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Tanggal Hari Pertama Haid (HPHT)"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvHasilHPHT"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HPHT: Belum dipilih\nPerkiraan Lahir (HPL): -"
            android:textColor="#FF1976D2"
            android:textStyle="italic"
            android:textSize="15sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daftar Sekarang"
            android:textSize="16sp"
            android:textStyle="bold"
            android:minHeight="54dp" />

    </LinearLayout>
</ScrollView>